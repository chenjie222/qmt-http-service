# QMT Server 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 必需：xtquant 库路径
QMT_XTQUANT_PATH=D:/software/54QMT/国金证券QMT交易端/bin.x64/Lib/site-packages

# 可选：交易功能配置
QMT_USERDATA_PATH=D:/software/54QMT/国金QMT交易端模拟/userdata_mini
QMT_ACCOUNT_ID=90007183
QMT_ACCOUNT_TYPE=STOCK

# 可选：服务配置
QMT_SERVER_HOST=0.0.0.0
QMT_SERVER_PORT=8080
QMT_LOG_LEVEL=INFO

# 可选：限流配置
QMT_RATE_LIMIT_ENABLED=true
QMT_RATE_LIMIT_RPM=60